APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Restrict Filament/web to this host so API subdomain only serves API routes (optional; leave empty in local dev)
# APP_DOMAIN=wera.dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wera
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Integrations (optional)
# GITHUB_TOKEN=           # For creating GitHub issues from tasks

# OAuth (Filament Socialite – login with GitHub/Google). Callback URLs:
#   GitHub: {APP_URL}/workspaces/oauth/callback/github
#   Google: {APP_URL}/workspaces/oauth/callback/google
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI="${APP_URL}/workspaces/oauth/callback/github"
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/workspaces/oauth/callback/google"
# WhatsApp service (pm2 start ecosystem.config.cjs). Uses APP_URL for callbacks; defaults: PORT 3000, APP_URL http://localhost:8000
# WHATSAPP_BAILEYS_URL=   # Laravel calls this (default: http://localhost:3000)
# WHATSAPP_SERVICE_PORT=  # Optional (default: 3000)
# WHATSAPP_CALLBACK_TOKEN= # Optional: token for Baileys→Laravel callbacks

# Laravel AI (agents: development plan, progress report) - set at least one provider
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
